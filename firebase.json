{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/buyer-rfqs",
        "destination": "/buyer-rfqs.html"
      },
      {
        "source": "/buyer-rfq",
        "destination": "/buyer-rfqs.html"
      },
      {
        "source": "/buyer-rfq.html",
        "destination": "/buyer-rfqs.html"
      }
    ]
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ================= RFQs =================
    match /rfqs/{id} {
      allow create, read: if true;

      allow update, delete: if
        request.auth != null &&
        request.auth.token.email.lower() == "admin@apdglobaltrade.com";
    }

    // ================= SUPPLIERS =================
    match /suppliers/{id} {

      allow read, update: if
        request.auth != null && (request.auth.uid == id || request.auth.token.email.lower() == "admin@apdglobaltrade.com");

      allow create: if true;

      // Allow admin to delete legacy/test accounts from the UI
      allow delete: if 
        request.auth != null && 
        request.auth.token.email.lower() == "admin@apdglobaltrade.com";
    }
    
    // ================= FRANCHISE APPLICATIONS =================
    match /franchise_applications/{id} {
      allow create: if true;
      
      allow read, update, delete: if
        request.auth != null &&
        request.auth.token.email.lower() == "admin@apdglobaltrade.com";
    }
  }
}
